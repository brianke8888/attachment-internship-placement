# Server
PORT=5000

# MySQL (for local dev — Docker uses env vars from docker-compose.yml)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=attachment_system

# JWT
JWT_SECRET=change_this_to_a_random_secret
JWT_EXPIRES_IN=7d

# Email (optional — leave unset to use Ethereal test emails in dev)
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_SECURE=false
# MAIL_USER=your@email.com
# MAIL_PASS=your-app-password
# MAIL_FROM="PlacementHub" <noreply@yourdomain.com>

# ──────────────────────────────────────────────────────
# Docker: To run with Docker Compose:
#   docker compose up -d --build
#
# The .env file at the project root can set:
#   DB_PASSWORD=yourpassword
#   DB_NAME=attachment_system
#   JWT_SECRET=your-secret
#   MAIL_HOST=smtp.gmail.com
#   MAIL_USER=your@email.com
#   MAIL_PASS=your-app-password
#   MAIL_FROM="PlacementHub" <noreply@yourdomain.com>
#
# Then seed the database:
#   docker compose exec backend node seed.js
# ──────────────────────────────────────────────────────
