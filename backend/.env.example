# Server
PORT=5000

# MySQL (supports both custom vars and Railway's MYSQL* vars)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=attachment_system

# Railway auto-sets these when you add a MySQL service:
# MYSQLHOST, MYSQLUSER, MYSQLPASSWORD, MYSQLDATABASE, MYSQLPORT

# JWT
JWT_SECRET=change_this_to_a_random_secret
JWT_EXPIRES_IN=7d

# Email (optional — leave unset to use Ethereal test emails in dev)
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_SECURE=false
# MAIL_USER=your@email.com
# MAIL_PASS=your-app-password
# MAIL_FROM="PlacementHub" <noreply@yourdomain.com>
